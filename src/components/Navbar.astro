---
import Logo from "./Logo.astro";
---

<nav>
  <div class="content">
    <Logo class="logo" />
    <div class="links">
      <a href="#">Inicio</a>
      <a href="#AboutMe">Sobre mí</a>
      <a href="#Projects">Proyectos</a>
      <a href="#Contact">Contacto</a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 1rem;
    width: 100%;
    display: flex;
    justify-content: center;
    z-index: 50;
    pointer-events: none;
  }
  .content {
    display: flex;
    width: var(--contentWidth);
    justify-content: space-between;
    align-items: center;
    text-align: center;
    border: 1px solid var(--borderSoft);
    border-radius: 999px;
    padding: 0.8rem 1.2rem;
    background: rgba(8, 14, 27, 0.72);
    backdrop-filter: blur(14px);
    box-shadow: 0 14px 35px rgba(4, 10, 20, 0.3);
    pointer-events: auto;
  }
  .links {
    display: flex;
    gap: 1.35rem;
    align-items: center;
  }
  .links a {
    font-family: "Cascadia Code Variable", monospace;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--textMuted);
  }
  .links a:hover {
    color: var(--accentColor);
  }
  @media (max-width: 900px) {
    .content {
      flex-direction: column;
      border-radius: 1.1rem;
      gap: 0.75rem;
      width: min(92vw, 600px);
      padding: 1rem;
    }
    .links {
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.9rem;
    }
  }
</style>
