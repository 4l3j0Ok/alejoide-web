APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=0.1.0

DEV_MODE=False
CLEAR_DB_ON_STARTUP=False

DB_TYPE=sqlite

LOG_LEVEL=INFO

# El fetch a /api/projects.json es server-side (Astro proxy), no llega directo al API desde el browser.
# CORS aplica solo si se expone el API directamente al browser en el futuro.
CORS_ALLOW_ORIGINS=https://alejoide.com

# URL pública desde donde el browser carga las imágenes.
# nginx proxea https://alejoide.com/images/ → http://projects-api:8000/images/
IMAGES_BASE_URL=https://alejoide.com/images
